NODE_ENV=production
PORT=7310
APP_HTTP_PORT=8080
API_HTTP_PORT=7310
BVS_PUBLIC_API_BASE_URL=https://api.wiiicare.example.vn/api/v1
BVS_REPOSITORY=postgres
BVS_AUTH_SECRET=change-me-with-a-random-secret-of-at-least-32-characters
BVS_AUTH_TOKEN_TTL_SECONDS=28800
BVS_DEMO_AUTH_ENABLED=false
BVS_CORS_ORIGINS=https://wiiicare.example.vn
BVS_POSTGRES_REPOSITORY_POOL_MAX=2
BVS_RATE_LIMIT_STORE=valkey
BVS_VALKEY_URL=redis://valkey:6379
BVS_AUTH_LOGIN_RATE_LIMIT_MAX=20
BVS_AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=60
BVS_RECORD_TRANSFER_RETRY_WORKER_ENABLED=false
BVS_RECORD_TRANSFER_RETRY_WORKER_INTERVAL_SECONDS=60
BVS_RECORD_TRANSFER_RETRY_WORKER_LIMIT=25
BVS_RECORD_TRANSFER_RETRY_WORKER_MAX_RETRY_COUNT=3
BVS_RECORD_TRANSFER_RETRY_WORKER_RUN_IMMEDIATELY=false

POSTGRES_USER=bvs
POSTGRES_PASSWORD=change-me-with-a-strong-password
POSTGRES_DB=benh_vien_so
DATABASE_URL=postgresql://bvs:change-me-with-a-strong-password@postgres:5432/benh_vien_so

MINIO_ROOT_USER=bvs_minio
MINIO_ROOT_PASSWORD=change-me-with-a-strong-password
OBJECT_STORAGE_ENDPOINT=http://minio:9000

FHIR_BASE_URL=http://hapi-fhir:8080/fhir
ORTHANC_BASE_URL=http://orthanc:8042
